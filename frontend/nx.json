{
  "extends": "nx/presets/npm.json",
  "affected": {
    "defaultBase": "main"
  },
  "workspaceLayout": {
    "appsDir": "client",
    "libsDir": "packages"
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/tasks-runners/default",
      "options": {
        "cacheableOperations": ["build"]
      }
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"]
    }
  },
  "projects": {
    "client": {
      "root": "frontend/client",
      "sourceRoot": "frontend/client/src",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/next:build",
          "options": {
            "outputPath": "frontend/client/.next"
          }
        }
      }
    }
  }
}
